# MongoDB Connection String (Get from MongoDB Atlas)
# Format: mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0
MONGO_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# JWT Secret Key for authentication (Use a strong secret)
JWT_SECRET=your_super_secret_key_change_this_in_production

# Server Port
PORT=5000

# Environment
NODE_ENV=production


